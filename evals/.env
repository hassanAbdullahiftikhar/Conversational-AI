# Gateway
GATEWAY_URL=http://localhost:8000
EVAL_MODE=true

# LLM Judge (Using local LLM as judge)
JUDGE_PROVIDER=openai
JUDGE_MODEL=local-model
JUDGE_API_KEY=dummy
JUDGE_BASE_URL=http://localhost:11434/v1

# Local LLM endpoints (Ollama/llama.cpp)
LLM_ENDPOINT=http://localhost:11434/v1
EMBEDDINGS_ENDPOINT=http://localhost:11434/v1

# Optional overrides
TRIALS_PER_SCENARIO=5              # reduce to 5 for fast smoke test
