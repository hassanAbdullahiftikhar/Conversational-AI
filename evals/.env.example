# Gateway
GATEWAY_URL=http://localhost:8000
EVAL_MODE=true

# LLM Judge
JUDGE_PROVIDER=anthropic            # anthropic | openai
JUDGE_MODEL=claude-sonnet-4-20250514
JUDGE_API_KEY=your_api_key_here

# Local LLM endpoints (llama.cpp)
LLM_ENDPOINT=http://localhost:8080/v1
EMBEDDINGS_ENDPOINT=http://localhost:8080/v1

# Optional overrides
TRIALS_PER_SCENARIO=30              # reduce to 5 for fast smoke test
